---
import '@/styles/global.css';
import { getConfig } from '@/lib/config';

interface Props {
  title?: string;
}

const config = getConfig();
const { title = `${config.name} - ${config.title}` } = Astro.props;
const theme = config.theme ?? 'blue';
const seo = config.seo;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {seo?.description && <meta name="description" content={seo.description} />}
    <meta property="og:title" content={title} />
    {seo?.description && <meta property="og:description" content={seo.description} />}
    {seo?.ogImage && <meta property="og:image" content={`${Astro.site ?? ''}${base}${seo.ogImage}`} />}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {seo?.description && <meta name="twitter:description" content={seo.description} />}
    {seo?.ogImage && <meta name="twitter:image" content={`${Astro.site ?? ''}${base}${seo.ogImage}`} />}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme-mode');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 font-sans min-h-screen transition-colors">
    <main class="max-w-3xl mx-auto px-4 sm:px-6 pt-20 pb-12">
      <slot />
    </main>

    <button
      id="theme-toggle"
      class="fixed bottom-6 right-6 w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-700 shadow-lg flex items-center justify-center hover:opacity-90 transition-opacity no-print"
      aria-label="다크모드 전환"
    >
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-700 hidden dark:block dark:text-yellow-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-700 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>

    <button
      id="scroll-top"
      class="fixed bottom-[4.5rem] right-6 w-10 h-10 rounded-full bg-accent text-white shadow-lg opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center hover:opacity-90 no-print"
      aria-label="맨 위로 이동"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      const toggleBtn = document.getElementById('theme-toggle');
      toggleBtn?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme-mode', isDark ? 'dark' : 'light');
      });

      const scrollBtn = document.getElementById('scroll-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          scrollBtn?.classList.remove('opacity-0', 'pointer-events-none');
          scrollBtn?.classList.add('opacity-100');
        } else {
          scrollBtn?.classList.add('opacity-0', 'pointer-events-none');
          scrollBtn?.classList.remove('opacity-100');
        }
      });
      scrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
