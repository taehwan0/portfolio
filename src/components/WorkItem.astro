---
interface Props {
  title: string;
  subtitle?: string;
  period: string;
  company?: string;
  tags: string[];
  logo?: string;
  Content: any;
}

const { title, subtitle, period, company, tags, logo, Content } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div>
  <div class="flex items-center gap-5 mb-10">
    {logo && (
      <img
        src={`${base}${logo}`}
        alt={title}
        class="w-24 h-24 rounded-full object-contain shrink-0"
      />
    )}
    <div>
      <p class="text-2xl font-bold dark:text-white">{title}</p>
      <div class="flex items-baseline gap-2 mt-1">
        {company && <span class="text-base text-gray-500 dark:text-gray-400">{company}</span>}
        <span class="text-sm text-gray-400 dark:text-gray-500">{period}</span>
      </div>
    </div>
  </div>
  <div class="prose">
    <Content />
  </div>
</div>
